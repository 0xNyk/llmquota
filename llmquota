#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks (e.g. ~/.local/bin/llmquota -> this repo) so ROOT is the
# real package directory. Never cd: bus/active-selection read the caller cwd.
SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

if [[ -f "$ROOT/dist/index.js" ]]; then
  exec node "$ROOT/dist/index.js" "$@"
fi

if [[ -x "$ROOT/node_modules/.bin/tsx" ]]; then
  exec "$ROOT/node_modules/.bin/tsx" "$ROOT/src/index.ts" "$@"
fi

echo "llmquota: run \`pnpm install && pnpm build\` first" >&2
exit 1
