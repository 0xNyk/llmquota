{
  "name": "llmquota",
  "version": "0.1.0",
  "description": "Fun terminal roster for Claude / Codex / Cursor / Grok / Hermes (Nous) rate limits",
  "type": "module",
  "bin": {
    "llmquota": "./llmquota"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xNyk/llmquota.git"
  },
  "bugs": {
    "url": "https://github.com/0xNyk/llmquota/issues"
  },
  "homepage": "https://github.com/0xNyk/llmquota#readme",
  "keywords": [
    "claude",
    "codex",
    "cursor",
    "grok",
    "hermes",
    "rate-limit",
    "quota",
    "cli",
    "tui"
  ],
  "author": "0xNyk",
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "llmquota",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "llmquota": "tsx src/index.ts",
    "who": "tsx src/index.ts who",
    "doctor": "tsx src/index.ts doctor",
    "tui": "tsx src/index.ts tui",
    "test": "tsc && node dist/tui-mouse.test.js && node dist/catalog.test.js && node dist/tui-card-body.test.js && node dist/arena-moves.test.js && node dist/bus.test.js && node dist/provider-usage.test.js && node dist/grok-probe.test.js && node dist/reset-dates.test.js",
    "test:mouse": "tsc && node dist/tui-mouse.test.js",
    "scan": "tsx src/index.ts scan",
    "prepublishOnly": "pnpm test"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^7.0.2"
  }
}
